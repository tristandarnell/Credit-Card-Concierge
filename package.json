{
  "name": "credit-card-concierge",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "rewards:collect": "node scripts/collect-rewards.mjs",
    "rewards:discover": "DISCOVERY_ONLY=1 node scripts/collect-rewards.mjs",
    "rewards:audit": "node scripts/audit-rewards-data.mjs",
    "rewards:sync": "node scripts/sync-rewards-to-supabase.mjs",
    "rewards:collect-and-sync": "npm run rewards:collect && npm run rewards:sync",
    "test:normalize": "npx tsx scripts/test-normalize.ts",
    "generate:statement": "npx tsx scripts/generate-synthetic-statement.ts",
    "train:classifier": "python ml/train.py",
    "train:classifier:sample": "python ml/train.py --sample 50000",
    "train:classifier:brands": "python ml/train.py --data synthetic_brand_name_merchant_credit_card_transactions.csv",
    "predict": "python ml/predict.py",
    "test:classifier": "python ml/test_classifier.py"
  },
  "dependencies": {
    "@faker-js/faker": "^10.3.0",
    "natural": "^8.1.0",
    "next": "15.1.6",
    "pdf-parse": "^1.1.4",
    "pdfkit": "^0.17.2",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "string-similarity": "^4.0.4"
  },
  "devDependencies": {
    "@types/natural": "^5.1.5",
    "@types/node": "22.13.10",
    "@types/pdfkit": "^0.17.5",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "@types/string-similarity": "^4.0.2",
    "eslint": "9.21.0",
    "eslint-config-next": "15.1.6",
    "tsx": "^4.21.0",
    "typescript": "5.7.3"
  }
}
